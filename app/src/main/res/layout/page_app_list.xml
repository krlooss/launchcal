<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black">

    <EditText
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search apps"
        android:textColor="@android:color/white"
        android:textColorHint="#888888"
        android:backgroundTint="#888888"
        android:inputType="text"
        android:imeOptions="actionDone"
        android:singleLine="true"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/appList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp" />

    <LinearLayout
        android:id="@+id/dockBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#1A1A1A">

        <ImageView
            android:id="@+id/dockPhone"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_dock_phone"
            android:scaleType="centerInside"
            android:contentDescription="Phone" />

        <ImageView
            android:id="@+id/dockBrowser"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_dock_browser"
            android:scaleType="centerInside"
            android:contentDescription="Browser" />

        <ImageView
            android:id="@+id/dockCamera"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ic_dock_camera"
            android:scaleType="centerInside"
            android:contentDescription="Camera" />

    </LinearLayout>

</LinearLayout>
